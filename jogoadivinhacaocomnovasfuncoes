import tkinter as tk
from tkinter import messagebox
import random

class JogoAdivinhacao:
    def __init__(self, master): # Construtor da classe JogoAdivinhacao, que é chamado quando um objeto dessa classe é criado. Ele recebe um parâmetro "master", que é a janela principal do Tkinter onde a interface gráfica será construída.
        self.master = master # Referência para a janela principal do Tkinter
        master.title("ADS FG - Jogo de Adivinhação") # Título da janela
        master.geometry("420x560") # Tamanho da janela
        
        # Lógica do jogo

        self.numero_secreto = random.randint(1, 100) # Gera um número aleatório entre 1 e 100 para ser o número secreto que o jogador deve adivinhar
        self.tentativas = 0 # Variável para contar o número de tentativas do jogador


        # --- Interface gráfica ---
        # 1. Título

        self.label_titulo = tk.Label(master, text="Adivinhe o Número\n(1 a 100)", font=("Arial", 16)) # Cria um rótulo (label) para o título do jogo, com o texto "Adivinhe o Número (1 a 100)" e a fonte Arial tamanho 16
        self.label_titulo.pack(pady=20) 

        # Campo de entrada (onde o usuario digita)
        
        self.entrada_chute = tk.Entry(master, font=("Arial", 12)) # Cria um campo de entrada para o usuário digitar seu chute, com a fonte Arial tamanho 12
        self.entrada_chute.pack(pady=10) # Adiciona um espaço vertical de 10 pixels entre o campo de entrada e os outros elementos da interface gráfica
        self.entrada_chute.bind("<Return>", lambda event: self.processar_chute()) # Permite que o usuário pressione Enter para enviar o chute, além de clicar no botão "Chutar!"

        # Botão para Enviar o chute

        self.botao_chutar = tk.Button( # Cria um botão para o usuário enviar seu chute, com o texto "Chutar!"
            master, text="Chutar!", command=self.processar_chute, 
            bg="#4CAF50", fg="white", font=("Arial", 12) # Define a cor de fundo do botão para verde, a cor do texto para branco e a fonte Arial tamanho 12.
        )
        self.botao_chutar.pack(pady=10)

        self.botao_dica = tk.Button( # Cria um botão para o usuário solicitar uma dica, com o texto "Dica"
            master, text = "Dica", command=self.processar_dica, bg="#FFDE21", fg = "white", font=("Arial", 12)
        )
        self.botao_dica.pack(pady=10)
        # Área de Feedback (Dicas)

        self.label_feedback = tk.Label(master, text="", font=("Arial", 10), fg="blue")
        self.label_feedback.pack(pady=10)

        # Botão para Reiniciar o jogo

        self.botao_reiniciar = tk.Button( # Cria um botão para o usuário reiniciar o jogo.
            master, text="Reiniciar Jogo", command=self.reiniciar, font=("Arial", 8)
        )
        self.botao_reiniciar.pack(side="bottom", padx=10)

    # Funções que unem a lógica do jogo com a interface gráfica

    def processar_chute(self): # Função que é chamada quando o usuário envia um chute.
        try:
            chute = int(self.entrada_chute.get()) # Pega o valor digitado
            self.tentativas += 1
            self.entrada_chute.delete(0, tk.END) # Limpa o campo de entrada

            if chute < 1 or chute > 100: # Verifica se o chute é válido (entre 1 e 100)
                self.label_feedback.config(text="Erro: Digite entre 1 e 100!", fg="red")

            elif chute == self.numero_secreto: # Verifica se o chute é igual ao número secreto
                messagebox.showinfo(
                    "Parabéns!",
                    f"Você acertou!\nNúmero: {self.numero_secreto}\nTentativas: {self.tentativas}"
                )
                self.label_feedback.config(text="Você ganhou!", fg="green")
                self.botao_chutar.config(state="disabled") # Desabilita o botão após ganhar

            elif chute > self.numero_secreto: # Verifica se o chute é maior que o número secreto 
                self.label_feedback.config(text=f"Tentativa {self.tentativas}: É MENOR...", fg="blue")

            else: # Verifica se o chute é menor que o número secreto
                self.label_feedback.config(text=f"Tentativa {self.tentativas}: É MAIOR...", fg="blue")

        except ValueError: # Trata o caso em que o usuário digitar algo que não seja um número inteiro, exibindo uma mensagem de erro.
            messagebox.showwarning("Entrada Inválida", "Por favor, digite apenas números válidos.")

    def reiniciar(self): # Função para reiniciar o jogo, gerando um novo número secreto.
        self.numero_secreto = random.randint(1, 100) # Gera um novo
        self.tentativas = 0 # Reseta o contador de tentativas
        self.entrada_chute.delete(0, tk.END) # Limpa o campo de entrada
        self.label_feedback.config(text="Jogo reiniciado!", fg="black") # Atualiza o rótulo de feedback para indicar que o jogo foi reiniciado
        self.botao_chutar.config(state="normal") # Reabilita o botão

    def processar_dica(self): # Função para fornecer uma dica ao jogador, indicando em qual faixa o número secreto está localizado.
            if self.numero_secreto <= 20: # Verifica se o número secreto está entre 1 e 20
                self.label_feedback.config(text="O número está entre 1 e 20", fg="orange")

            elif self.numero_secreto >= 21 and self.numero_secreto <= 40: # Verifica se o número secreto está entre 21 e 40
                self.label_feedback.config(text="O número está entre 21 e 40")

            elif self.numero_secreto >= 41 and self.numero_secreto <= 60: # Verifica se o número secreto está entre 41 e 60
                self.label_feedback.config(text="O número está entre 41 e 60")

            elif self.numero_secreto >= 61 and self.numero_secreto <= 80: # Verifica se o número secreto está entre 61 e 80
                self.label_feedback.config(text="O número está entre 61 e 80")

            else: # Verifica se o número secreto está entre 81 e 100
                self.label_feedback.config(text="O número está entre 81 e 100")
        
    # Inicialização do jogo

if __name__ == "__main__": # Verifica se o script está sendo executado diretamente. Ele cria a janela principal do Tkinter e inicia o jogo.

    root = tk.Tk() # Cria a janela principal do Tkinter

    jogo = JogoAdivinhacao(root) # Cria uma instância do jogo de adivinhação, passando a janela principal como argumento
    
    root.mainloop() # Inicia o loop principal do Tkinter, que mantém a janela aberta e permite a interação do usuário com a interface gráfica.
